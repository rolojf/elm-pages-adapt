{
  "name": "solarpaq",
  "type": "module",
  "scripts": {
    "postinstall:comment": "To be run automatically when first installing",
    "postinstall": "elm-tooling install",
    "elm:comment": "Development server runs on port 1234 by default",
    "elm": "elm-pages dev",
    "cli:comment": "The run commands from the L-Pages CLI.",
    "cli": "elm-pages/generator/src/cli.js",
    "build:comment": "build for production",
    "build": "tailwindcss -i input.css -o tailwind.css --minify && elm-pages build",
    "server:comment": "Run a server on dist/ build",
    "server": "python -m http.server 8421 --bind 127.0.0.12 --directory dist",
    "tail:comment": "Generate the tailwind css classes and css files to be used dev server",
    "tail": "tailwindcss -i input.css -o tailwind.css",
    "asdf:comment": "Deploy to S3 - deprecitated",
    "asdf": "aws s3 sync ./dist s3://solarpaq.com --delete"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "autoprefixer": "^10.4.20",
    "elm-codegen": "^0.6.1",
    "elm-optimize-level-2": "^0.3.5",
    "elm-pages": "3.5.1",
    "elm-review": "^2.12.0",
    "elm-tooling": "^1.15.1",
    "lamdera": "^0.19.1-1.4.0",
    "postcss": "^8.4.29",
    "tailwindcss": "^3.4.15",
    "vite": "^7.3.1",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "dependencies": {
    "@netlify/functions": "^3.0.0"
  }
}
